<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A12">

    <!-- ── Top Bar: User name + ID ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#12121E"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Player"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tv_user_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mirror 100"
            android:textSize="14sp"
            android:textColor="#6C63FF"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── Your Coins ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="10dp"
        android:background="#1A1A2A">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🪙 Your Coins: "
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_my_coins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="500"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Players Grid ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎮 Players"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="8dp" />

            <!-- Player 1 (YOU) -->
            <LinearLayout
                android:id="@+id/player1_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_bg"
                android:padding="12dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 "
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_p1_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You"
                        android:textColor="#4ADE80"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_p1_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting..."
                        android:textColor="#888888"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_p1_coins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪙 500"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Player 2 (Bot) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_bg"
                android:padding="12dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖 "
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_p2_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rahim"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_p2_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting..."
                        android:textColor="#888888"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_p2_coins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪙 500"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Player 3 (Bot) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_bg"
                android:padding="12dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖 "
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_p3_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Karim"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_p3_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting..."
                        android:textColor="#888888"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_p3_coins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪙 500"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Player 4 (Bot) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/card_bg"
                android:padding="12dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖 "
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_p4_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sumon"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_p4_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting..."
                        android:textColor="#888888"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_p4_coins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪙 500"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── Game Area: Pick a number ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tv_game_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎲 Pick a number (1-4) and place your bet!"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="14dp" />

                <!-- Number buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="14dp">

                    <Button
                        android:id="@+id/btn_pick_1"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:text="1"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#6C63FF"
                        android:layout_marginEnd="10dp" />

                    <Button
                        android:id="@+id/btn_pick_2"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:text="2"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#6C63FF"
                        android:layout_marginEnd="10dp" />

                    <Button
                        android:id="@+id/btn_pick_3"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:text="3"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#6C63FF"
                        android:layout_marginEnd="10dp" />

                    <Button
                        android:id="@+id/btn_pick_4"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:text="4"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#6C63FF" />
                </LinearLayout>

                <!-- Bet amount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bet: "
                        android:textColor="#CCCCCC"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/btn_bet_10"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="10"
                        android:textColor="#FFD700"
                        android:backgroundTint="#2A2A3A"
                        android:layout_marginEnd="6dp"
                        android:minWidth="52dp" />

                    <Button
                        android:id="@+id/btn_bet_50"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="50"
                        android:textColor="#FFD700"
                        android:backgroundTint="#2A2A3A"
                        android:layout_marginEnd="6dp"
                        android:minWidth="52dp" />

                    <Button
                        android:id="@+id/btn_bet_100"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="100"
                        android:textColor="#FFD700"
                        android:backgroundTint="#2A2A3A"
                        android:layout_marginEnd="6dp"
                        android:minWidth="52dp" />

                    <Button
                        android:id="@+id/btn_bet_200"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="200"
                        android:textColor="#FFD700"
                        android:backgroundTint="#2A2A3A"
                        android:minWidth="52dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_selected_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select a number and bet amount"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <!-- Play button -->
                <Button
                    android:id="@+id/btn_play_round"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="🎲 Play Round"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#4CAF50"
                    android:enabled="false" />
            </LinearLayout>

            <!-- ── Result Area ── -->
            <LinearLayout
                android:id="@+id/result_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tv_result_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 3"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#FFD700"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_result_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="You Win!"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#4ADE80"
                    android:gravity="center"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_result_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+300 coins"
                    android:textSize="16sp"
                    android:textColor="#CCCCCC"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
