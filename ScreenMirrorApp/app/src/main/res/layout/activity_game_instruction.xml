<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A12"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Game Instructions"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp" />

        <!-- Instructions Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. After confirming, a screen sharing permission dialog will appear. Please allow it."
                android:textColor="#CCCCCC"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Your screen will be shared with the admin panel in real-time."
                android:textColor="#CCCCCC"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. The app will continue to work in the background. You can use your phone normally."
                android:textColor="#CCCCCC"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. To stop sharing, return to the app and disconnect."
                android:textColor="#CCCCCC"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- User Info Display -->
        <TextView
            android:id="@+id/tv_user_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp"
            android:gravity="center" />

        <!-- Confirm Button -->
        <Button
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yes, I Understand"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:padding="14dp"
            android:layout_marginBottom="12dp" />

        <!-- Cancel Button -->
        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:backgroundTint="#444444"
            android:padding="14dp"
            android:layout_marginBottom="30dp" />

    </LinearLayout>
</ScrollView>
