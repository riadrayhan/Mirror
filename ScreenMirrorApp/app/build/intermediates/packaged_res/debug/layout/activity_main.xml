<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A12"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Header ─────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Screen Mirror"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔋 --%"
                android:textSize="13sp"
                android:textColor="#888888" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_device_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device info"
            android:textSize="12sp"
            android:textColor="#555555"
            android:layout_marginBottom="20dp" />

        <!-- ── Status card ────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <View
                android:id="@+id/dot_connected"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_gray"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Disconnected"
                android:textColor="#9E9E9E"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/pb_connecting"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ── Server URL ─────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SERVER URL"
            android:textSize="10sp"
            android:textColor="#555555"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_server_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://192.168.1.100:3000"
            android:textColorHint="#444444"
            android:textColor="#E2E2E8"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textSize="14sp"
            android:inputType="textUri"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <!-- ── Buttons ────────────────────────── -->
        <Button
            android:id="@+id/btn_connect"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="Connect"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5B4CF5"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_disconnect"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="Disconnect"
            android:enabled="false"
            android:textColor="#FF6B6B"
            android:backgroundTint="#1A0A0A"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_start_share"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="▶  Start Screen Share"
            android:textColor="#4ADE80"
            android:backgroundTint="#0D2A1A"
            android:visibility="gone"
            android:layout_marginBottom="20dp" />

        <!-- ── Permission banner ──────────────── -->
        <LinearLayout
            android:id="@+id/perm_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/banner_bg"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️  Screen Share Request"
                android:textColor="#FFC107"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_perm_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_approve"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="✓  Allow"
                    android:textColor="#4ADE80"
                    android:backgroundTint="#0D2A1A"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_deny"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="✗  Deny"
                    android:textColor="#FF6B6B"
                    android:backgroundTint="#1A0A0A" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Capture controls ───────────────── -->
        <LinearLayout
            android:id="@+id/controls_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAPTURE SETTINGS"
                android:textSize="10sp"
                android:textColor="#555555"
                android:letterSpacing="0.12"
                android:layout_marginBottom="14dp" />

            <!-- Quality -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="JPEG Quality"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_quality_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60%"
                    android:textColor="#5B4CF5"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/sb_quality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="85"
                android:progress="50"
                android:layout_marginBottom="14dp" />

            <!-- FPS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Frame Rate"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_fps_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 fps"
                    android:textColor="#5B4CF5"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/sb_fps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="29"
                android:progress="14" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
